# OpenAI
OPENAI_API_KEY=sk-proj_xxx
OPENAI_MODEL=gpt-5.1

# Neon Postgres. Use the pooled connection string in Vercel/serverless.
DATABASE_URL=postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Internal CRM login. Use a long random AUTH_SECRET and a temporary shared code for MVP login.
AUTH_SECRET=un-secreto-largo-y-random
INTERNAL_LOGIN_CODE=codigo-temporal

# WhatsApp Cloud API / Meta
WHATSAPP_VERIFY_TOKEN=un-token-largo-para-validar-webhook
WHATSAPP_ACCESS_TOKEN=EAAG...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_APP_SECRET=

# Vercel Blob. Required for direct uploads of larger videos/files.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# Cloudflare R2 para media pesada (imagenes, audios, videos y documentos)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# FEBECOS platform connector
FEBECOS_API_BASE_URL=https://api.febecos.com
FEBECOS_API_TOKEN=xxxxx
FEBECOS_WEBHOOK_TOKEN=token-compartido-con-selector
FEBECOS_PUBLIC_URL=https://febecos.com
FEBECOS_SELECTOR_API_BASE_URL=https://selector.febecos.com/api

# Optional: internal escalation destination
FEBECOS_HUMAN_SUPPORT_LABEL=Equipo FEBECOS

# Resend (aviso interno de comprobantes de pago a administracion@)
# Mismo transporte que el resto del ecosistema Febecos. Dominio febecos.com verificado en Resend.
RESEND_API_KEY=
RESEND_FROM=Febecos Ventas <ventas@febecos.com>
PAYMENT_NOTIFY_TO=administracion@febecos.com
